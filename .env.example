# ============================================================
# AI Loan Assistance – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_NAME="AI Loan Assistant"
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=loan_assistance
POSTGRES_USER=loan_user
POSTGRES_PASSWORD=changeme

# ── pgvector ─────────────────────────────────────────────────
VECTOR_DIMENSION=1536        # text-embedding-3-small = 1536

# ── Redis Cache ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=              # Leave empty for development, set for production

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── OpenTelemetry ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-loan-assistance
OTEL_ENABLED=false           # set true in staging/prod

# ── MCP Server ───────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001

# ── AWS (deployment readiness) ───────────────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=loan-documents-bucket

